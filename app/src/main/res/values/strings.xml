    <!-- About Screen strings -->
    <string name="about_title">About App</string>
    <string name="about_app_description">The official MIS Parent Application of Colegio de Alicia. Designed to empower parents with real-time access to their child\'s academic journey.</string>
    <string name="about_mission_title">Our Mission</string>
    <string name="about_mission_content">To bridge the communication gap between the institution and guardians, ensuring that every parent can actively support their child\'s education with convenience and transparency.</string>
