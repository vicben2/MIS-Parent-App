    <!-- Legal strings -->
    <string name="about_tos_title">Terms of Service</string>
    <string name="about_tos_content">By using the MIS Parent App, you agree to abide by the institutional rules of Colegio de Alicia. The app is intended for authorized guardians to monitor academic progress through secure access.</string>

    <string name="about_privacy_title">Privacy Policy</string>
    <string name="about_privacy_content">We are committed to protecting your data. This application collects authentication credentials and academic records solely for the purpose of educational monitoring. All data is handled in compliance with institutional privacy standards.</string>

    <string name="about_disclaimer_title">Legal Disclaimers</string>
    <string name="about_disclaimer_content">This software is provided on an \"as is\" basis. While we strive for 100% accuracy, Colegio de Alicia and its developers are not liable for incidental or consequential damages resulting from the use of this app.</string>

    <string name="about_compliance_title">Regulatory Compliance</string>
    <string name="about_compliance_content">This application adheres to local data privacy acts and standards for educational record protection, ensuring student information remains confidential and secure.</string>

